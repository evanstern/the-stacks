#!/usr/bin/env bash
# pre-commit — fast local mirror of CI's gate suite (no pnpm install, no network).
# Enable once per clone: git config core.hooksPath .githooks
# (in the bare+worktree layout that lands in .bare/config, so every worktree inherits it).
# CI stays authoritative: core.hooksPath is per-clone and trivially bypassed with --no-verify.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

node scripts/check-boundaries.mjs
node --test scripts/*.test.mjs
node scripts/check-spec-artifacts.mjs
node scripts/check-adrs.mjs
