#!/usr/bin/env bash
# pre-push — the gates that only make sense against origin: the version-bump
# contract and wiki freshness. Enable once per clone: git config core.hooksPath .githooks
# CI stays authoritative; this exists to fail before the round-trip.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

# Bare clones (this repo's .bare layout) have no fetch refspec by default, so
# origin/main may not exist as a tracking ref; fall back to local main. Fix
# properly with: git config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'
base="origin/main"
git rev-parse -q --verify "$base" >/dev/null || base="main"
node scripts/check-version-bump.mjs --base "$base"

# Wiki freshness + board check need a praxis checkout (PRAXIS_DIR or
# ~/projects/praxis). Prefer the versioned runner (run-gates.mjs, v0.4.0+ —
# the same contract the CI action wraps); fall back to the plugin CLI on older
# checkouts. Absent praxis we defer to CI rather than block.
praxis="${PRAXIS_DIR:-$HOME/projects/praxis}"
# Physical path: run-gates.mjs's run-as-CLI guard breaks through symlinked
# paths (silent exit 0 — no gates run). pwd -P resolves the real location.
if [ -d "$praxis" ]; then praxis="$(cd "$praxis" && pwd -P)"; fi
if [ -f "$praxis/scripts/run-gates.mjs" ]; then
  node "$praxis/scripts/run-gates.mjs" --gates spec-bridge,wiki-freshness --path .
elif [ -f "$praxis/grounding-wiki/gates/cli.mjs" ]; then
  node "$praxis/grounding-wiki/gates/cli.mjs" freshness . docs/wiki
else
  echo "warn: praxis not found at $praxis — wiki freshness deferred to CI" >&2
fi
