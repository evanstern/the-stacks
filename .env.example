OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
SESSION_COOKIE_SECURE=false
# Runtime versions derive their own database names and URLs from this base connection string.
DATABASE_URL=postgresql+psycopg://thestacks:thestacks@postgres:5432/thestacks
QDRANT_URL=http://qdrant:6333
# Shared base collection name. Runtime version collections are derived internally from version IDs.
QDRANT_COLLECTION=thestacks_chunks
# Shared upload root. Immutable source archives and version-specific runtime prefixes live under this root.
UPLOAD_DIR=/data/uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5175,http://127.0.0.1:5175,http://localhost:5176,http://127.0.0.1:5176,http://localhost:5177,http://127.0.0.1:5177,http://localhost:5178,http://127.0.0.1:5178,http://localhost:5179,http://127.0.0.1:5179,http://localhost:5180,http://127.0.0.1:5180,http://localhost:3000
RETRIEVAL_TOP_K=8
