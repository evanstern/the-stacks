# v3 environment contract — see specs/007-v3-skeleton/contracts/environment.md
# Copy to .env and fill in the two required secrets below.

# ---------------------------------------------------------------------------
# Required — no safe default, you must set these
# ---------------------------------------------------------------------------

# bcrypt hash of the operator password (single-operator auth, D13).
# Generate with:
#   node -e "console.log(require('bcrypt').hashSync(process.argv[1], 10))" -- 'your-password'
# IMPORTANT: Docker Compose interpolates .env values, so every literal `$` in
# the hash must be escaped as `$$` (e.g. `$2b$10$abc...` -> `$$2b$$10$$abc...`)
# or compose will silently mangle it into a blank/partial string.
OPERATOR_PASSWORD_HASH=

# >=32 random characters; keys the sealed session cookie. Rotating this value
# invalidates all existing sessions. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ---------------------------------------------------------------------------
# Stack identity & ports — defaults chosen to avoid collisions across parallel
# worktrees, and distinct from the retired v2 stack's ports (research R3, ADR 0001)
# ---------------------------------------------------------------------------

COMPOSE_PROJECT_NAME=the-stacks-v3
V3_WEB_PORT=4400
V3_API_PORT=4401
V3_ML_PORT=4402
V3_POSTGRES_PORT=5442

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

V3_POSTGRES_DB=stacks_v3
V3_POSTGRES_USER=stacks_v3
V3_POSTGRES_PASSWORD=stacks_v3
DATABASE_URL=postgresql://stacks_v3:stacks_v3@postgres:5432/stacks_v3

# ---------------------------------------------------------------------------
# Model role: embedding (D14, FR-013) — named, env-first. Never hardcode model
# identifiers in product code; this is the one place they live.
# ---------------------------------------------------------------------------

EMBEDDING_PROVIDER=local-sidecar
EMBEDDING_ENDPOINT=http://ml:4402
EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
ML_EMBEDDING_MODEL=${EMBEDDING_MODEL_ID}
EMBED_MAX_BATCH=64
ML_REQUEST_TIMEOUT_MS=15000

# ---------------------------------------------------------------------------
# Ingestion (spec 008) — intake caps and chunking policy.
# Chunking params are char-based on purpose (tokenizers are model-specific and
# D14 forbids baking one in) and exist as env so the eval program (doc 06) can
# vary them without code surgery — see specs/008-ingestion-service/research.md R4.
# ---------------------------------------------------------------------------

# Upload cap, also the per-ZIP-entry cap. 25 MB: saved HTML pages and exports
# are comfortably under this; bytea archives stay sane (research R1).
INGEST_MAX_UPLOAD_BYTES=26214400
# Max entries a single ZIP may expand into (research R6 bounds the fan-out).
INGEST_MAX_BATCH_ENTRIES=200
# Chunk packing budget (~1k tokens at the usual 4 chars/token heuristic).
CHUNK_TARGET_CHARS=4000
# Prose-only overlap between adjacent chunks; atomic kinds never overlap.
CHUNK_OVERLAP_CHARS=400
# Hard budget: an ATOMIC section (stat block / table / spell entry) larger than
# this becomes ONE oversized, flagged chunk — never split (008 SC-009).
CHUNK_MAX_CHARS=6000

# ---------------------------------------------------------------------------
# Auth & sessions
# ---------------------------------------------------------------------------

SESSION_COOKIE_SECURE=false

# ---------------------------------------------------------------------------
# Worker & queue
# ---------------------------------------------------------------------------

WORKER_POLL_MS=2000
WORKER_VISIBILITY_TIMEOUT_MS=60000
JOB_MAX_ATTEMPTS=3

# ---------------------------------------------------------------------------
# Web
# ---------------------------------------------------------------------------

API_INTERNAL_URL=http://api:4401
