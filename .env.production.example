# Copy to .env.production for the production compose/deploy path.
# .env.production and .env.production.local are gitignored; never commit them.
# Keep real API keys, bcrypt hashes, database passwords, and session secrets out of the repo.

# Required: public host port for The Stacks production container/router binding.
# This is intentionally separate from the local dev compose port contract on 5173.
APP_HOST_PORT=8423

# Required: OpenAI key for chat completions and embeddings.
# Format: sk-...
OPENAI_API_KEY=

# Required: OpenAI model settings. Keep embedding dimensions aligned with the model
# and with any existing Qdrant collection vectors before reusing persisted data.
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Required: bcrypt hash for the production admin password.
# Generate out-of-band; do not store the plaintext password in any env file.
ADMIN_PASSWORD_HASH=

# Required: high-entropy cookie signing secret. Rotating this logs out all sessions.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Required: production cookies must only be sent over HTTPS.
SESSION_COOKIE_SECURE=true

# Optional: keep the default cookie contract unless intentionally migrating clients.
SESSION_COOKIE_NAME=thestacks_session
SESSION_TTL_SECONDS=604800

# Required: Postgres connection string for the production database.
# Use a production-only password and keep the Postgres data directory on persistent storage.
# Example shape only:
#   postgresql+psycopg://thestacks:<postgres-password>@postgres:5432/thestacks
# Runtime versions derive their own database names and URLs from this base connection string.
DATABASE_URL=postgresql+psycopg://thestacks:<postgres-password>@postgres:5432/thestacks

# Required: Qdrant endpoint and collection for production retrieval.
# Keep Qdrant storage on persistent storage; do not share the dev collection unless intended.
# Runtime version collections are derived internally from version IDs.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=thestacks_chunks

# Required: persistent upload directory shared by API and worker containers.
# The production compose/deploy path must mount durable storage here.
# Immutable source archives and version-specific runtime prefixes are stored beneath this root.
UPLOAD_DIR=/data/uploads

# Required: production browser origin allowed to call the API.
CORS_ORIGINS=https://thestacks.ikis.ai

# Optional: retrieval tuning.
RETRIEVAL_TOP_K=8
RETRIEVAL_MIN_SCORE=0.2

# Optional: upload/archive safety limits.
ARCHIVE_MAX_ZIP_SIZE_BYTES=157286400
ARCHIVE_MAX_EXTRACTED_SIZE_BYTES=367001600
ARCHIVE_MAX_FILE_COUNT=2000

# Optional: worker polling cadence in seconds.
WORKER_POLL_SECONDS=5

# Required when the web image/runtime needs to call the public API from the browser.
VITE_API_URL=https://thestacks.ikis.ai

# Persistence contract for production operators:
# - Postgres: persist /var/lib/postgresql/data; local compose uses named volume main-postgres-data.
# - Qdrant: persist /qdrant/storage; local compose uses named volume main-qdrant-data.
# - Uploads: persist and share /data/uploads between API and worker; local compose uses named volume main-uploads.
# - Production storage must be separate from the dev compose stack and must survive container rebuilds/recreates.
